# Copy to `.env` and edit values for local overrides.
# Variables not set here fall back to the defaults baked into docker-compose.yml.

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=stacksift
POSTGRES_PASSWORD=stacksift_secret
POSTGRES_DB=stacksift

# ── RabbitMQ ──────────────────────────────────────────────────────
RABBITMQ_USER=stacksift
RABBITMQ_PASS=stacksift_secret

# ── Keycloak master-realm admin (the /admin console) ──────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# ── Keycloak backend-admin service-account client ─────────────────
# The .NET backend uses this to call /admin/realms/stacksift/users
# (NUF-1). The realm JSON ships with the literal "REPLACE_AT_RUNTIME"
# as a placeholder; the real value is generated by Keycloak on first
# boot and must be copied from the admin UI into
#   `dotnet user-secrets set "Keycloak:Admin:AdminClientSecret" "<value>"`
# for local dev, or set here for docker-compose runs of the backend.
Keycloak__Admin__AdminClientSecret=REPLACE_ME
