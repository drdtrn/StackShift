{
  "uid": "stacksift-postgres-dba",
  "title": "Postgres — DBA",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["stacksift", "postgres", "dba"],
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Postgres up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pg_up", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Active connections",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(pg_stat_activity_count{state=\"active\"})", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Connection saturation",
      "description": "Active / max_connections.",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(pg_stat_activity_count) / pg_settings_max_connections", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queries per second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit[5m]) + rate(pg_stat_database_xact_rollback[5m]))",
          "refId": "A",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Slow queries (rate / 5m)",
      "description": "Rate of statements whose total exec time exceeds 250ms (Decision 0.10). Source: pg_stat_statements via the exporter.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_statements_mean_exec_time_seconds[5m]) > 0.25",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Long-running transactions (> 60s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_max_tx_duration > 60",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Locks held",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (mode) (pg_locks_count)",
          "refId": "A",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tuple ops (insert / update / delete)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_tup_inserted[5m]))", "refId": "A", "legendFormat": "insert" },
        { "expr": "sum(rate(pg_stat_database_tup_updated[5m]))",  "refId": "B", "legendFormat": "update" },
        { "expr": "sum(rate(pg_stat_database_tup_deleted[5m]))",  "refId": "C", "legendFormat": "delete" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database size",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "refId": "A",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
