{
  "uid": "stacksift-api-health",
  "title": "API Health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["stacksift", "api"],
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "API Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "up{job=\"stacksift-api\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Code",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [{ "expr": "sum by (code) (rate(http_requests_received_total{job=\"stacksift-api\"}[5m]))", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "P99 Latency by Route",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=\"stacksift-api\"}[5m])))", "refId": "A" }]
    },
    {
      "type": "table",
      "title": "Top Error Routes",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "topk(10, sum by (route, code) (rate(http_requests_received_total{job=\"stacksift-api\",code=~\"5..\"}[15m])))", "refId": "A", "format": "table" }]
    }
  ]
}
