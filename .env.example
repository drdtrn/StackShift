# StackSift — environment template
#
# Copy to `.env.local` and fill in the marked values:
#   cp .env.example .env.local
#
# .env.local is gitignored. Production deploys read these same keys from
# the cluster's secret manager (Plan 08 §9 — External Secrets Operator).
#
# Most values default to dev-friendly placeholders that match the docker-
# compose stack. The lines marked CHANGE-ME must be supplied for the
# matching feature to work.

# -----------------------------------------------------------------------------
# Compose build metadata (optional, used for OCI labels on the images)
# -----------------------------------------------------------------------------
GIT_SHA=local
BUILD_DATE=local

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_DB=stacksift
POSTGRES_USER=stacksift
POSTGRES_PASSWORD=stacksift_secret

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=stacksift
RABBITMQ_PASS=stacksift_secret

# -----------------------------------------------------------------------------
# MinIO (S3-compatible blob store for user uploads + logo storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# -----------------------------------------------------------------------------
# Keycloak — bootstrapping admin account, NOT the runtime client secret.
# Runtime client secret is in the realm import JSON and is rotated via
# the admin console (Plan 05).
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# Public URL the browser uses to reach Keycloak. Inside the docker network
# the api/frontend services use http://keycloak:8080 (hard-coded in
# docker-compose.yml). Override here if you front Keycloak with a proxy.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Dashboard / frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5190
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cloudflare Turnstile site key (public). Leave blank to disable the register
# captcha widget locally. Pair with backend Captcha__SecretKey.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Abuse protection (backend) — leave Captcha__SecretKey blank to skip captcha
# verification (dev/test). Cloudflare test secret: 1x0000000000000000000000000000000AA
# -----------------------------------------------------------------------------
Captcha__SecretKey=

# -----------------------------------------------------------------------------
# Stripe — CHANGE-ME (get from https://dashboard.stripe.com → Developers →
# API keys, and a webhook secret from Webhooks → Local listener for the
# webhook secret). Run `stripe listen --forward-to localhost:5190/api/v1/
# billing/webhook` while developing.
# -----------------------------------------------------------------------------
Stripe__ApiKey=sk_test_CHANGE_ME
Stripe__WebhookSecret=whsec_CHANGE_ME
Stripe__Prices__Indie=price_CHANGE_ME
Stripe__Prices__Team=price_CHANGE_ME

# -----------------------------------------------------------------------------
# OpenAI — CHANGE-ME (https://platform.openai.com/api-keys). Free
# `text-embedding-3-small` + `gpt-4o-mini` is enough for development.
# Without this key, AI analyses transition to Failed with a clear message.
# -----------------------------------------------------------------------------
OpenAI__ApiKey=sk-CHANGE_ME

# -----------------------------------------------------------------------------
# Keycloak — client + admin secrets (CHANGE-ME). Rotate the admin client
# secret via Keycloak admin console → Clients → stacksift-backend-admin.
# The bearer-client secret in `Keycloak__Credentials__Secret` lives in the
# realm-import JSON for now (Plan 05 will move it here).
# -----------------------------------------------------------------------------
Keycloak__Credentials__Secret=qhioxydPArAwOyUbfdHCItm7WvrOTaiK
Keycloak__Admin__AdminClientSecret=CHANGE_ME

# -----------------------------------------------------------------------------
# Log source API-key pepper (Plan 02). Base64-encoded, must decode to >=32
# bytes. Generate with `openssl rand -base64 32`. Rotating this invalidates
# every existing log-source API key, so production rotates only on suspected
# compromise (Plan 12 §10). Local dev can keep this constant across resets.
# -----------------------------------------------------------------------------
LogSources__KeyPepperBase64=AA2BzvzqHoIWZfRQ4VHUh41zCy4IuiXHjkL+VXdwvfI=
